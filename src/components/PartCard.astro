---
interface Props {
  part: {
    name: string;
    price: string;
    image: string;
  };
}

const { part } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100 hover:shadow-2xl transition group">
  <div class="relative h-64 overflow-hidden">
    <img src={part.image} alt={part.name} class="w-full h-full object-cover transform group-hover:scale-110 transition duration-500" />
  </div>
  <div class="p-6">
    <h3 class="text-2xl font-bold text-gray-900 mb-2">{part.name}</h3>
    <div class="text-3xl font-black text-indigo-700 mb-6">{part.price}</div>
    <a href="https://wa.me/77017230470" target="_blank" class="block w-full text-center bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-4 rounded-lg transition">
      Запросить цену
    </a>
  </div>
</div>